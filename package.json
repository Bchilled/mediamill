{
  "name": "forge-video-factory",
  "version": "0.1.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:renderer": "vite",
    "build": "vite build && electron-builder --win",
    "start": "electron ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "axios": "^1.6.7",
    "electron-store": "^8.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "googleapis": "^140.0.1",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bigsexygiantkiller.forge",
    "productName": "FORGE",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist-electron"
    }
  }
}
